# .env.example — copy to .env and fill in values before starting
# Never commit the real .env file.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

POSTGRES_PASSWORD=change-me

# ── Recommended ───────────────────────────────────────────────────────────────
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Database (defaults match docker-compose.yml service names)
POSTGRES_DB=opencirt
POSTGRES_USER=opencirt
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=opencirt
DATABASE_USER=opencirt
DATABASE_HOST=db
DATABASE_PORT=5432

# ── Optional — AI features ────────────────────────────────────────────────────
# Anthropic is preferred when set; OpenAI is the fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Optional — IOC enrichment ─────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ── Optional — Demo data ──────────────────────────────────────────────────────
# Set to "true" to load sample incidents on first migrate (dev/demo only).
LOAD_DEMO_DATA=false
